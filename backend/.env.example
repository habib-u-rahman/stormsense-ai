OPENAI_API_KEY=your_key_here
GROQ_API_KEY=your_key_here
OPENWEATHER_API_KEY=your_key_here
NASA_FIRMS_API_KEY=your_key_here

# Notifier Agent (optional) — only used by the autonomous background monitor,
# never by chat queries. Leave blank to skip email alerts entirely.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_gmail_app_password
ALERT_EMAIL_TO=recipient@example.com

# Minutes to wait before re-sending the same ongoing alert (avoids spam)
NOTIFICATION_COOLDOWN_MINUTES=30
