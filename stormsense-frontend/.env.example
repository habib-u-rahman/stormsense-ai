# URL of the StormSense AI backend (FastAPI).
#
# Local development: leave this blank/unset — the app defaults to
# http://localhost:8000 automatically (via next.config.ts and lib/api.ts).
#
# Deployment: set this to your deployed backend's URL, e.g.
# NEXT_PUBLIC_API_URL=https://your-backend.onrender.com
#
# Must be NEXT_PUBLIC_ prefixed since it's also read in the browser to
# open the live-update WebSocket connection.
NEXT_PUBLIC_API_URL=https://stormsense-ai.onrender.com
